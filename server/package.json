{
  "name": "3dparthub-server",
  "version": "2.8.6",
  "type": "module",
  "scripts": {
    "dev": "node --import tsx src/main.ts",
    "dev:local": "PORT=8000 API_WORKERS=1 node --import tsx src/cluster.ts",
    "dev:watch": "tsx watch src/main.ts",
    "start": "node --import tsx src/cluster.ts",
    "test": "DATABASE_URL=postgresql://test:test@localhost:5432/test JWT_SECRET=test-secret node --import tsx --test src/**/*.test.ts",
    "test:coverage": "DATABASE_URL=postgresql://test:test@localhost:5432/test JWT_SECRET=test-secret node --import tsx --test --experimental-test-coverage src/**/*.test.ts 2>&1 | node -e \"process.stdin.setEncoding('utf8');let d='';process.stdin.on('data',c=>d+=c);process.stdin.on('end',()=>{process.stdout.write(d);const m=d.match(/(\\d+\\.?\\d*)% coverage/);if(m&&parseFloat(m[1])<50){console.error('\\nCoverage below 50% threshold');process.exit(1)}})\"",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.ts\" \"prisma/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"prisma/*.ts\"",
    "verify": "npm run typecheck && npm run lint && npm run format:check && npm run build && npm test",
    "prisma:generate": "bash scripts/safe-migrate.sh generate",
    "prisma:migrate": "bash scripts/safe-migrate.sh dev",
    "prisma:deploy": "bash scripts/safe-migrate.sh deploy",
    "prisma:backup": "bash scripts/safe-migrate.sh backup",
    "prisma:force-reset": "bash scripts/safe-migrate.sh force-reset",
    "prisma:studio": "prisma studio",
    "preview-meta:migrate": "tsx scripts/migrate-preview-meta.ts",
    "backup:e2e": "tsx scripts/backup-e2e-check.ts",
    "seed:batch": "tsx prisma/seeds/run-batch.ts",
    "seed:all": "tsx prisma/seeds/import-selection-products.ts",
    "seed:range": "tsx prisma/seeds/run-batch.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.3",
    "canvas": "^3.2.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.7",
    "multer": "^1.4.5-lts.2",
    "node-unrar-js": "^2.0.2",
    "nodemailer": "^8.0.5",
    "occt-import-js": "^0.0.23",
    "pino": "^10.3.1",
    "prisma": "^5.22.0",
    "puppeteer-core": "^24.41.0",
    "svg-captcha": "^1.4.0",
    "three": "^0.175.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^8.0.0",
    "@types/three": "^0.175.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "globals": "^17.4.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.5.3",
    "tsx": "^4.19.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.58.0"
  }
}
