{
  "name": "3dparthub-server",
  "version": "2.4.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "start": "node --import tsx src/cluster.ts",
    "build": "tsc",
    "prisma:generate": "bash scripts/safe-migrate.sh generate",
    "prisma:migrate": "bash scripts/safe-migrate.sh dev",
    "prisma:deploy": "bash scripts/safe-migrate.sh deploy",
    "prisma:backup": "bash scripts/safe-migrate.sh backup",
    "prisma:force-reset": "bash scripts/safe-migrate.sh force-reset",
    "prisma:studio": "prisma studio",
    "backup:e2e": "tsx scripts/backup-e2e-check.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.74.1",
    "canvas": "^3.2.3",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.1.0",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "minio": "^8.0.7",
    "multer": "^1.4.5-lts.2",
    "nodemailer": "^8.0.5",
    "occt-import-js": "^0.0.23",
    "prisma": "^5.22.0",
    "puppeteer-core": "^24.41.0",
    "svg-captcha": "^1.4.0",
    "three": "^0.175.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@types/adm-zip": "^0.5.8",
    "@types/archiver": "^7.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^1.4.12",
    "@types/nodemailer": "^8.0.0",
    "@types/three": "^0.175.0",
    "@types/uuid": "^10.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
