    "@react-three/postprocessing": "^3.0.4",
    "@sentry/react": "^10.51.0",
    "@types/three": "^0.184.0",
    "axios": "^1.15.0",
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.8.0",
    "occt-import-js": "^0.0.23",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-dropzone": "^15.0.0",
