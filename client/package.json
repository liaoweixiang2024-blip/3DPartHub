    "eslint": "^9.39.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "msw": "^2.13.4",
    "prettier": "^3.5.3",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
