{
  "name": "3dparthub",
  "private": true,
  "scripts": {
    "build": "npm --prefix client run build && npm --prefix server run build",
    "dev:local": "bash scripts/start-local.sh",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3"
  },
  "lint-staged": {
    "client/src/**/*.{ts,tsx}": [
      "prettier --write"
    ],
    "server/src/**/*.ts": [
      "prettier --write"
    ],
    "server/prisma/*.ts": [
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  }
}
