# ===== Server =====
PORT=8000
DATABASE_URL=postgresql://modeluser:modelpass@localhost:5432/3dparthub
REDIS_URL=redis://localhost:6379
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d
UPLOAD_DIR=uploads
STATIC_DIR=static
MAX_FILE_SIZE=104857600
ALLOWED_ORIGINS=http://localhost:5173

# ===== Admin Account (first run only) =====
ADMIN_USER=admin
ADMIN_EMAIL=admin@model.local
ADMIN_PASS=change-me-before-first-start

# ===== SMTP (optional, for registration codes) =====
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASS=

# ===== MinIO (optional, default: local storage) =====
# STORAGE_TYPE=minio
# MINIO_ENDPOINT=localhost
# MINIO_PORT=9000
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_BUCKET=models
